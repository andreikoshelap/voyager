# Copy to /opt/voyage-log/voyage-log.env on the server (chmod 600, owned by
# the voyagelog user). Never commit the real file — this is a template only.

SPRING_PROFILES_ACTIVE=prod

# Native PostgreSQL on this box runs on the default port (5432), unlike the
# local docker-compose setup which used 5433 to avoid clashing with a
# native install on a dev machine. No such clash here.
DB_URL=jdbc:postgresql://localhost:5432/voyagelog
DB_USER=voyagelog
DB_PASSWORD=Again2020_

TELEGRAM_BOT_TOKEN=8997702047:AAHHueIZaSrbUtf6ZzevcKmTsm5uEV7SaYs
TELEGRAM_WEBHOOK_SECRET=d43c3ac59a8550c4da6464ce11ff8d32

PUBLIC_BASE_URL=https://voyage.gatto-piccolo.com

# Distinct from portfell-admin (8081) and whatever ledger-api uses on this
# box — verify with `sudo ss -tlnp` before first deploy in case something
# else already claimed 8083.
SERVER_PORT=8083
